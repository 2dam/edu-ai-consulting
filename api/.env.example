# 공공데이터포털(data.go.kr) 서비스키 — 어린이집/유치원 기초현황 활용신청 후 발급
DATA_GO_KR_SERVICE_KEY=

# 실시간 교육 동영상 패널 — YouTube Data API v3 (https://console.cloud.google.com 에서
